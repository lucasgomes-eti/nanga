# Token do bot (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=

# Application ID (Discord Developer Portal -> General Information -> Application ID)
DISCORD_CLIENT_ID=

# Opcional: ID do servidor de testes. Se setado, slash commands são
# registrados nesse servidor (propagacao instantanea). Se vazio, registra
# globalmente (pode levar ate 1 hora para aparecer).
DISCORD_GUILD_ID=

# Cookies do YouTube em base64. Necessario quando o bot esta hospedado em
# IPs de datacenter (Railway, Fly, etc) — o YouTube exige autenticacao para
# evitar "Sign in to confirm you're not a bot". Use uma CONTA DESCARTAVEL,
# exporte cookies.txt do navegador (formato Netscape) e base64-encode.
YOUTUBE_COOKIES_B64=
